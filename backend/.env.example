# ═══════════════════════════════════════════════════════════
# ASLICONNECT Backend — Environment Variables
# Copy this file to .env and fill in real values.
# ═══════════════════════════════════════════════════════════

# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=*

# Database — EITHER set DATABASE_URL (Render/Railway/Supabase style)
# OR set the individual DB_* vars for local Postgres.
DATABASE_URL=postgresql://user:password@localhost:5432/asliconnect
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=asliconnect

# Auth
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Razorpay (escrow payments) — leave blank to run in demo/simulation mode
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
